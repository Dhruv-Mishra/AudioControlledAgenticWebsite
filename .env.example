# Copy to .env and fill in. .env is gitignored.

# ----------- Required -----------
# Google Gemini API key with Live API access.
GEMINI_API_KEY=your_gemini_api_key_here

# ----------- Networking -----------
# Port the Node server listens on. Default 3011.
PORT=3011

# Comma-separated list of allowed browser Origins for the WS upgrade.
# Leave blank to auto-allow localhost/127.0.0.1 in dev.
# ALLOWED_ORIGINS=https://jarvis.whoisdhruv.com

# ----------- Runtime mode -----------
# `production` serves minified assets from dist/ with long Cache-Control.
# Anything else serves source from the tree with no-cache. Defaults to dev.
# NODE_ENV=production

# Debug logging (writes per-session bridge events to stdout).
# DEBUG=1

# ----------- Feature flags -----------
# Include Gemini Live server-side transcription (inputAudioTranscription +
# outputAudioTranscription) in the Live config. Default false → save STT
# credits. When false AND SHOW_TEXT=true, the browser falls back to the
# local Web Speech API for user-side transcription only.
# GEMINI_TRANSCRIPTION=false

# Render the transcript panel and tool args/values in activity logs.
# Default true. When false: transcript panel hidden; activity log shows
# tool NAMES only (no args, no results); server redacts text from logs.
# The debug metrics panel (?debug=1) stays functional either way.
# SHOW_TEXT=true

# ----------- Model overrides (rare) -----------
# Pin a specific Gemini Live model; leave unset for the default preview.
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Pin the non-Live model used by /api/eval.
# GEMINI_EVAL_MODEL=gemini-2.5-flash

# Emit sourcemaps during `npm run build`. Default off for smaller artefacts.
# SOURCEMAPS=true
