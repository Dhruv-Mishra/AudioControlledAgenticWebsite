# Copy this file to deploy/system.env.local and adjust it for the machine.
# This file is for machine-specific deployment settings only.

# Docker Compose project name. Keeps container/network names distinct.
COMPOSE_PROJECT_NAME=freightops

# Image name/tag produced by `docker compose build`.
IMAGE_NAME=dhruv-freightops:latest

# Optional immutable image reference for CI/CD deploys, for example:
# IMAGE_REF=ghcr.io/owner/repo@sha256:abcdef...
# When set, deploy scripts pull this image instead of building locally.
# IMAGE_REF=

# App env file injected into the container. Relative paths resolve from the
# repo root. Keep secrets in that file, not here.
APP_ENV_FILE=.env

# Host port publishing. Keep HOST_BIND=127.0.0.1 when a reverse proxy or TLS
# terminator sits in front of the container.
HOST_BIND=127.0.0.1
HOST_PORT=3011

# Internal container port. Leave this alone unless you have a strong reason.
CONTAINER_PORT=3011

# Post-deploy health check target used by deploy/deploy.mjs.
HEALTHCHECK_PROTOCOL=http
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PORT=3011
HEALTHCHECK_PATH=/api/health
HEALTHCHECK_TIMEOUT_MS=60000